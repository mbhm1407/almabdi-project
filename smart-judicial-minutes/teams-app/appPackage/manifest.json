{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "packageName": "sa.gov.smartjudicialminutes",
  "developer": {
    "name": "Smart Judicial Minutes",
    "websiteUrl": "https://${{APP_DOMAIN}}",
    "privacyUrl": "https://${{APP_DOMAIN}}/privacy",
    "termsOfUseUrl": "https://${{APP_DOMAIN}}/terms"
  },
  "name": {
    "short": "المحضر الذكي",
    "full": "المحضر الذكي — Smart Judicial Minutes"
  },
  "description": {
    "short": "نسخ مباشر للكلام العربي أثناء جلسات Microsoft Teams.",
    "full": "تطبيق اجتماعات لـ Microsoft Teams يساعد كاتب الجلسة على تدوين كل ما يُقال أثناء الجلسة عبر تحويل الكلام العربي إلى نص فوري مع اسم المتحدث والطابع الزمني، والبحث فيه وحفظه وتصديره. لا يقوم التطبيق بإنشاء محاضر رسمية أو إدارة قضايا. صُمّم وطُوّر بواسطة محمد المعبدي (mbmaabdi@moj.gov.sa)."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#217C46",
  "configurableTabs": [
    {
      "configurationUrl": "https://${{APP_DOMAIN}}/config",
      "canUpdateConfiguration": false,
      "scopes": ["groupChat"],
      "context": ["meetingSidePanel", "meetingChatTab", "meetingDetailsTab"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "smj-transcript",
      "name": "المحضر الذكي",
      "contentUrl": "https://${{APP_DOMAIN}}/",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "devicePermissions": ["media"],
  "validDomains": ["${{APP_DOMAIN}}"],
  "webApplicationInfo": {
    "id": "${{ENTRA_API_CLIENT_ID}}",
    "resource": "api://${{APP_DOMAIN}}/${{ENTRA_API_CLIENT_ID}}"
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "OnlineMeeting.ReadBasic.Chat",
          "type": "Delegated"
        }
      ]
    }
  }
}
