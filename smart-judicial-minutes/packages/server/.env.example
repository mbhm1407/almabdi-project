# ---- Runtime ----
NODE_ENV=development
PORT=3978
CORS_ORIGINS=https://teams.microsoft.com,https://localhost:5173

# ---- Microsoft Entra ID (API app registration) ----
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_SCOPE=access_as_user

# ---- Azure AI Speech ----
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=westeurope
SPEECH_LOCALE=ar-SA

# ---- Azure SQL ----
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=smartjudicialminutes
SQL_USER=sqladmin
SQL_PASSWORD=your-strong-password
SQL_USE_MANAGED_IDENTITY=false
SQL_ENCRYPT=true

# ---- Azure Blob Storage ----
BLOB_ACCOUNT_NAME=yourstorageaccount
BLOB_CONTAINER=recordings
# Optional: provide a connection string, otherwise managed identity is used.
# BLOB_CONNECTION_STRING=

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

LOG_LEVEL=info
